# Coinbase WS and Snapshot config
PRODUCT_IDS=BTC-USD,ETH-USD
CHANNELS=ticker,heartbeats
# COINBASE_API_JSON_FP=config/cdp_api_key.json

#Snapshots
SNAPSHOT_INTERVAL_MINUTES=5 #snapshot every X minutes
SNAPSHOT_TTL_HOURS=48 #keep X hours of interval snapshots in Redis 
EOD_HOUR=17
EOD_MINUTE=0
EOD_TZ=America/New_York
EOD_PRICE_STALE_THRESHOLD_MINUTES=10 #Mark EOD price received more than X minutes before closing as possible stale

# Redis (optional overrides — defaults match docker-compose)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Snowflake connection
SNOWFLAKE_ACCOUNT=<>
SNOWFLAKE_USER=<>
SNOWFLAKE_PASSWORD=<>
SNOWFLAKE_DATABASE=<>
SNOWFLAKE_SCHEMA=<>
SNOWFLAKE_WAREHOUSE=<>